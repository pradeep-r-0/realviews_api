<div style="margin-top: 30px;">
  <div class="max-w-md mx-auto space-y-4 pt-16" align="center">

    <%= form_with url: login_otp_path, method: :post do |f| %>

      <%= f.email_field :email,
            placeholder: "Enter your email",
            class: "w-full border rounded px-3 py-2" %>

      <%= f.submit "Continue with OTP",
            class: "w-full mt-3 bg-blue-600 text-white py-2 rounded" %>

    <% end %>

    <div class="text-center text-gray-500">
      or
    </div>

    <%= button_to "/auth/google_oauth2",
        method: :post,
        data: { turbo: false },
        class: "w-full" do %>

      <div class="flex items-center justify-center gap-3 rounded-lg border border-gray-300 bg-white px-4 py-3">
        
        <svg width="18" height="18" viewBox="0 0 48 48">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.91 2.38 30.4 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.14-3.09-.4-4.55H24v9.02h12.94c-.58 2.96-2.25 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.54 28.59A14.5 14.5 0 0 1 9.5 24c0-1.6.37-3.12 1.04-4.59l-7.98-6.19A23.94 23.94 0 0 0 0 24c0 3.87.93 7.53 2.56 10.78l7.98-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.92-2.13 15.89-5.8l-7.73-6c-2.15 1.44-4.91 2.3-8.16 2.3-6.26 0-11.57-4.22-13.46-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        <span>Continue with Google</span>
      </div>

    <% end %>

  </div>
</div>