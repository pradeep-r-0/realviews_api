<div class="centered-columns">
  <div class="column">

    <% @ownership = @car.ownerships.find_by_user_id(current_user.id) if current_user %>

    <h2 class="car-title">
      <%= @car.car_make.name %> <%= @car.model %>
      <span class="text-muted"><%= @car.variant %></span>
      <span class="text-muted">
        (<%= @car.fuel_type.eql?("CNG") ? @car.fuel_type : @car.fuel_type.chars.first %>)
      </span>
    </h2>

    <div class="center-block">
      <div class="field text-secondary field-bold">
        Model: <%= @car.date_of_purchase.strftime("%B %Y") %>
      </div>

      <div class="mileage-summary-wrapper">
        <table class="mileage-summary">
          <thead>
            <tr>
              <th colspan="2">Avg Mileage</th>
            </tr>
            <tr>
              <th>Before E20</th>
              <th>E20</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <%= calculate_avg_mileage(@non_e20_topups) %>
              </td>
              <td>
                <%= calculate_avg_mileage(@e20_topups) %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <% if current_user && @ownership&.user_id == current_user.id %>
        <div class="field">
          <%= link_to "View Full Refill History",
              ownership_fuel_topups_path(@ownership),
              class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
    
    <% e20_start_date = Date.new(2026, 4, 1) %>
    
    <table class="topups-table">
      <tr>
        <th>Date</th>
        <th>Fuel Brand</th>
        <th>Price</th>
        <th>Rate/Litre</th>
        <th>Odometer (kms)</th>
        <th>Mileage (kmpl)</th>
      </tr>

      <% prev_topup = nil %>

      <% @fuel_topups.each do |topup| %>
        <tr>
          <td><%= topup.topup_date.strftime("%d-%m-%Y") %></td>
          <td><%= topup.brand %></td>
          <td>₹<%= topup.price %></td>
          <td>₹<%= topup.rate_per_litre %></td>
          <td><%= topup.odometer_reading %></td>

          <% is_latest = (topup.id == @latest_topup_id) %>
          <% is_e20 = topup.topup_date >= e20_start_date %>
          <% mileage = topup.mileage_from(prev_topup) unless is_latest %>


          <td>
            <% if is_latest %>
                <span><i class='fas fa-fire-alt' style='color:orange'></i> Burning now</span>
            <% else %>
              <% if mileage.nil? %>
                -
              <% else %>
                  <%= formatted_mileage(
                    mileage: mileage,
                    is_latest: is_latest,
                    is_e20: is_e20
                  ) %>
              <% end %>
            <% end %>
          </td>


          <% prev_topup = topup %>
        </tr>
      <% end %>
    </table>

    <div class="fuel-cards">  
      <% @fuel_topups.each_with_index do |current_topup, index| %>
        <% next_topup = @fuel_topups[index - 1] if index > 0 %>

        <%= render partial: "fuel_topups/fuel_topup",
                  locals: { current_topup: current_topup, next_topup: next_topup,
                             index: index, latest_topup_id: @latest_topup_id,
                             e20_start_date: e20_start_date } %>
      <% end %>
    </div>


    <% if @fuel_topups.size < 2 %>
      <div class="field mileage">
        Add at least 2 fuel topup records to view mileage.
      </div>
    <% end %>

    <div class="center-block">
      <% if @ownership.present? %>
        <%= link_to "New Topup",
            new_ownership_fuel_topup_path(@ownership),
            class: "btn btn-primary" %>
      <% end %>
      <%= link_to 'Back', cars_path, class: "btn btn-primary" %>
    </div>

    <div class="qna-box">
      <ul>
        <li class="question">🤔 How does it work?</li>
        <li class="answer">
          We calculate based on kms between your consecutive topups
        </li>
      </ul>
    </div>

  </div>
</div>
